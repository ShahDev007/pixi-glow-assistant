# Pixi Glow Assistant environment variables.
# Copy to .env.local for local development. Set the same values in Vercel project
# settings for production. Never commit real secrets. All keys are server-side only.

# Required: Anthropic Messages API (the assistant).
ANTHROPIC_API_KEY=

# Required for persistence, RAG, and the live dashboard. Neon or Supabase Postgres.
# Use the pooled connection string for serverless.
DATABASE_URL=

# Embeddings for RAG. Set ONE. Voyage is preferred (1024-dim, matches the schema).
# If you use OpenAI instead (1536-dim), change vector(1024) in scripts/schema.sql
# to vector(1536) and re-run npm run seed.
VOYAGE_API_KEY=
# OPENAI_API_KEY=

# Optional connector credentials. Absence is intentional: it triggers the honest
# "connect to enable" behavior. Add these to take the integrations live.
# SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# SHOPIFY_ADMIN_TOKEN=
# KUSTOMER_API_KEY=
# NETSUITE_ACCOUNT_ID=
# NETSUITE_CONSUMER_KEY=
# NETSUITE_TOKEN_ID=
